# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values before `docker compose up`.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Replace with your VM's public IP (or domain) and the ports you expose.
# These MUST match what your browser actually uses to reach the app, or
# CORS / cookies will silently break.
CORS_ORIGIN=http://YOUR_VM_IP:3000
API_URL=http://YOUR_VM_IP:4000/graphql

# Any long random string. Used to sign session cookies.
# Generate one with:  openssl rand -hex 32
COOKIE_SECRET=change-me-to-a-long-random-string

# Postgres credentials. The defaults below are fine for a private VM, but
# change the password if Postgres is exposed beyond the docker network.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=quickpics

# Keep this `development` while you're accessing over plain HTTP.
# Switch to `production` ONLY after you put HTTPS in front of the app
# (otherwise express-session's `secure: true` cookies are dropped by the
# browser and login will appear to succeed but you stay logged out).
SERVER_NODE_ENV=development
